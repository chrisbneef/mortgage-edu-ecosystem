# Copy to .env (which is gitignored) and fill in. Used by `npm run podcast`.
# Never put real keys in this file — it is tracked in git. Put them in .env only.

# Paid Google Gemini API key (https://aistudio.google.com/apikey). Billing must be enabled
# for the TTS models. GOOGLE_API_KEY also works.
GEMINI_API_KEY=

# Vercel Blob store read/write token (Vercel dashboard -> Storage -> Blob -> create store).
# Starts with vercel_blob_rw_…  (the store ID is not needed by the pipeline, just the token.)
BLOB_READ_WRITE_TOKEN=

# Optional overrides:
# PODCAST_TEXT_MODEL=gemini-2.5-pro
# PODCAST_TTS_MODEL=gemini-2.5-flash-preview-tts
# PODCAST_HOST_A_NAME=Maya
# PODCAST_HOST_A_VOICE=Kore
# PODCAST_HOST_B_NAME=Theo
# PODCAST_HOST_B_VOICE=Alnilam
# PODCAST_TARGET_MIN=4
# PODCAST_CONCURRENCY=2
